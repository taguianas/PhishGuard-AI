# Local development
PORT=4000
NODE_ENV=development

# Shared JWT secret — must match frontend NEXTAUTH_SECRET exactly
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# ML service URL (local: http://localhost:8000, Render: set automatically via render.yaml)
ML_SERVICE_URL=http://localhost:8000

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# API keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here
GROQ_API_KEY=your_groq_api_key_here
