# Shared JWT secret — must match backend NEXTAUTH_SECRET exactly
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Your frontend URL (local dev: http://localhost:3000, Render: https://phishguard-frontend.onrender.com)
NEXTAUTH_URL=http://localhost:3000

# Backend URL — server-side only, used by proxy routes (set automatically in Render via render.yaml)
BACKEND_URL=http://localhost:4000

# Google OAuth (optional — leave blank to disable Google login button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=false
